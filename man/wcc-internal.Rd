\name{wcc-internal}
\alias{wccCalcCumR}
\alias{wccAggregateGrid}

\title{Internal wcc functions}

\description{
Internal helpers, not intended for direct use.  \code{wccCalcCumR} is the pure-R cumulative-sum reference used by \code{\link{wccCalc}} with \code{method="cumr"}; \code{wccAggregateGrid} is the aggregate-statistics helper shared by \code{\link{wccAggregate}} and the batched path of \code{\link{wccFindDyadParam}}.
}

\keyword{internal}
